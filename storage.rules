rules_version = '2';

// Comment image uploads. Each user can write only into their own folder
// (named by their Anonymous Auth uid). Anyone can read so attachments render
// on the comments. Files are capped at 2 MB and must be images.
service firebase.storage {
  match /b/{bucket}/o {

    match /comments/{uid}/{file=**} {
      allow read: if true;
      allow write: if
        request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
