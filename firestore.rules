rules_version = '2';

// Comments + feature requests require an authenticated user (Anonymous Auth
// counts). The author of a doc can update or delete only their own. Field
// caps prevent a misbehaving client from filling the database with junk.
//
// Deploy via console (paste into the Rules tab) or `firebase deploy --only firestore:rules`.
service cloud.firestore {
  match /databases/{database}/documents {

    match /comments/{id} {
      allow read: if true;

      allow create: if
        request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.item is string
        && request.resource.data.item.size() <= 200
        && request.resource.data.username is string
        && request.resource.data.username.size() <= 40
        && (!('text'     in request.resource.data) || (request.resource.data.text     is string  && request.resource.data.text.size()     <= 2000))
        && (!('rating'   in request.resource.data) || (request.resource.data.rating   is int     && request.resource.data.rating >= 1 && request.resource.data.rating <= 5))
        && (!('imageUrl' in request.resource.data) || (request.resource.data.imageUrl is string  && request.resource.data.imageUrl.size() <= 500))
        && (!('week'     in request.resource.data) || (request.resource.data.week     is string  && request.resource.data.week.size()     <= 16))
        // Clients may only set moderationStatus = "pending"; the moderate.mjs
        // Action (admin SDK) bypasses these rules to write "ok" / "blocked".
        && (!('moderationStatus' in request.resource.data) || request.resource.data.moderationStatus == "pending")
        && request.resource.data.createdAt == request.time;

      allow update: if
        request.auth != null
        && resource.data.authorId == request.auth.uid
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.item == resource.data.item
        && request.resource.data.createdAt == resource.data.createdAt
        && (!('text'     in request.resource.data) || (request.resource.data.text     is string  && request.resource.data.text.size()     <= 2000))
        && (!('rating'   in request.resource.data) || (request.resource.data.rating   is int     && request.resource.data.rating >= 1 && request.resource.data.rating <= 5))
        && (!('imageUrl' in request.resource.data) || (request.resource.data.imageUrl is string  && request.resource.data.imageUrl.size() <= 500))
        // Caps on optional fields the client can include.
        && (!('username' in request.resource.data) || (request.resource.data.username is string  && request.resource.data.username.size() <= 40))
        && (!('week'     in request.resource.data) || (request.resource.data.week     is string  && request.resource.data.week.size()     <= 16))
        // REQUIRE moderation reset on every edit — otherwise a user could
        // sneak banned text into a previously-approved doc by omitting the
        // field and relying on the old "ok" status sticking.
        && request.resource.data.moderationStatus == "pending";

      allow delete: if
        request.auth != null
        && resource.data.authorId == request.auth.uid;
    }

    // The feature_requests collection is no longer written by the site —
    // submissions now flow Browser → Cloudflare Worker → GitHub Issues
    // directly. The default deny-all rule applies. (Old documents from the
    // previous flow stay readable from the Firebase console.)
  }
}
